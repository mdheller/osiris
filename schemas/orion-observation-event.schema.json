{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/schemas/orion-observation-event.schema.json",
  "title": "OrionObservationEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "eventType",
    "observedAt",
    "location",
    "severity",
    "confidence",
    "sourceRecordRefs",
    "evidenceGrade",
    "policyState"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "eventId": {
      "type": "string",
      "pattern": "^orion-evt-[a-z0-9][a-z0-9._-]*$"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "natural_hazard.fire_weather_alert",
        "natural_hazard.seismic_event",
        "asset.facility",
        "cyber.cve_exposure",
        "field_report.operator_observation",
        "news.public_signal",
        "incident.fused_facility_risk",
        "recon.policy_required",
        "unknown"
      ]
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "observedAt": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "type": "string",
          "const": "Point"
        },
        "coordinates": {
          "type": "array",
          "prefixItems": [
            { "type": "number", "minimum": -180, "maximum": 180 },
            { "type": "number", "minimum": -90, "maximum": 90 }
          ],
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sourceRecordRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^gaia-src-[a-z0-9][a-z0-9._-]*$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "assetRefs": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "relatedEventRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^orion-evt-[a-z0-9][a-z0-9._-]*$"
      },
      "uniqueItems": true
    },
    "evidenceGrade": {
      "type": "string",
      "enum": [
        "fixture.synthetic",
        "public_source.unverified",
        "public_source.versioned",
        "public_source.attributed",
        "operator_report.unverified",
        "fused.inferred",
        "policy_gated.action"
      ]
    },
    "policyState": {
      "type": "string",
      "enum": [
        "public_view_allowed",
        "internal_view_allowed",
        "unverified_source",
        "attribution_required",
        "action_gated",
        "scope_required",
        "authorization_required",
        "expired"
      ]
    },
    "policyEnvelopeRef": {
      "type": "string",
      "pattern": "^orion-pol-[a-z0-9][a-z0-9._-]*$"
    },
    "decisionCardRef": {
      "type": "string",
      "pattern": "^orion-card-[a-z0-9][a-z0-9._-]*$"
    },
    "receiptRef": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
